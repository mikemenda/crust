rules_version = '2';

// ============================================================
// CRUST — Firebase Storage Security Rules
// Paste this into: Firebase Console → Storage → Rules tab
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    // Each user can only read/write their own photo folder
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
